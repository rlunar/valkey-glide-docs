---
import Default from '@astrojs/starlight/components/PageFrame.astro';
---

<Default {...Astro.props}>
    <slot name="header" slot="header" />
    
    <slot name="sidebar" slot="sidebar" />
    
    <slot />
</Default>

    <footer class="site-footer">
        <div class="footer-content">
            
            <div class="footer-top">
            <div class="footer-logo">
                <span class="logo-text">🚀 Valkey GLIDE</span> 
            </div>
            <div class="social-icons">
                <a href="#" aria-label="Discord">Discord</a>
                <a href="#" aria-label="GitHub">GitHub</a>
                <a href="#" aria-label="YouTube">YouTube</a>
                <a href="#" aria-label="Twitter">X</a>
                <a href="#" aria-label="LinkedIn">LinkedIn</a>
            </div>
            </div>

            <div class="footer-bottom">
            <div class="copyright-section">
                <span>© 2025 Valkey GLIDE, Inc. - All rights reserved</span>
            </div>
            
            <div class="footer-links">
                <a href="#">Legal notices</a>
                <a href="#">Privacy policy</a>
                <a href="#">Terms of service</a>
                <a href="#">Cookie preferences</a>
            </div>
            </div>

        </div>
    </footer>

<style>
  /* Scoped styles for the footer */
  .site-footer {
    background-color: #0b1221; /* Dark background from image */
    color: #aeb4be; /* Light grey text */
    padding: 2rem 0;
    margin-top: 3rem;
    font-size: 0.9rem;
    border-top: 1px solid #23262d;
  }

  .footer-content {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  /* Top Row Styling */
  .footer-top {
    display: flex;
    justify-content: space-between;
    align-items: center;
    border-bottom: 1px solid #1e293b;
    padding-bottom: 1.5rem;
  }

  .logo-text {
    font-weight: bold;
    color: white;
    font-size: 1.2rem;
  }

  .social-icons {
    display: flex;
    gap: 1rem;
  }

  .social-icons a {
    color: white;
    text-decoration: none;
    transition: opacity 0.2s;
  }

  .social-icons a:hover {
    opacity: 0.7;
  }

  /* Bottom Row Styling */
  .footer-bottom {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  /* Desktop layout for bottom row */
  @media (min-width: 768px) {
    .footer-bottom {
      flex-direction: row;
      justify-content: space-between;
      align-items: center;
    }
  }

  .footer-links {
    display: flex;
    gap: 1.5rem;
    flex-wrap: wrap;
  }

  .footer-links a {
    color: #aeb4be;
    text-decoration: none;
  }

  .footer-links a:hover {
    color: white;
    text-decoration: underline;
  }
</style>